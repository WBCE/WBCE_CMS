{% extends "_framer.twig" %}
{% block content %}  

<div class="cpForm">
    <form name="cmc_settings" action="{{ returnUrl }}" method="post">
        {{ FTAN }}

        {# ── Enabled / Disabled ───────────────────────────────────────────── #}
        <div class="formRow" id="dd-row-run">
            <div class="settingName">
                <label>{{ L_('TEXT:ENABLED') }}</label>
            </div>     
            <div class="settingValue">
                {% set current = cfg.run ?? false %}
                <label>
                    <input type="radio" name="run" value="1" id="dd-run-enabled"
                           {{ current == 1 or current == true ? 'checked' : '' }}>
                    {{ L_('TEXT:ENABLED') }}
                </label>
                <label>
                    <input type="radio" name="run" value="0" id="dd-run-disabled"
                           {{ current == 0 or current == false ? 'checked' : '' }}>
                    {{ L_('TEXT:DISABLED') }}
                </label>
            </div>
        </div>

        {# ── Settings rows — hidden when disabled ─────────────────────────── #}
        {# jQuery toggles visibility of this wrapper based on the run radio.   #}
        <div id="dd-settings-section">
            
            {# ── Debug Dump live preview ───────────────────────────────────────── #}
            <div class="formRow">        
                <div class="settingName">
                    <label>Debug Dump Output</label>
                </div>     
                {% if cfg.run == false %} 
                    <div class="settingValue"><code>{{ L_('TEXT:DISABLED') }}</code></div>                    
                {% else %}
                    <div id="hold-debug_dumper">
                        {{ debug_dump(demo_dump) }}
                    </div>
                {% endif %}
            </div>


            {# Height of dump window #}
            <div class="formRow">
                <div class="settingName"><label>Box-{{ L_('TEXT:HEIGHT') }}</label></div>
                <div class="settingValue">
                    <input 
                        type="number" 
                        name="height" 
                        step="25" 
                        min="100"  
                        maxlength="4"
                        oninput="this.value = this.value.slice(0,4)" 
                        value="{{ cfg.height }}"
                    /> px
                </div>
            </div>

            {# Theme #}
            <div class="formRow">
                <div class="settingName"><label>Theme</label></div>
                <div class="settingValue">
                    <select id="theme_sel" name="theme">
                        <option value="0" disabled>{{ L_('TEXT:PLEASE_SELECT') }} &hellip;</option>
                        {% for name in ['classic', 'dark'] %}
                            {% set sel = (name == cfg.theme) ? ' selected' : '' %}
                            <option value="{{ name }}"{{ sel }}>{{ name|capitalize }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            {# Font Family #}
            <div class="formRow">
                <div class="settingName">
                    <label>Font {{ L_('TEXT:NAME') }}</label>
                </div>            
                <div class="settingValue">
                    <select id="font_name_sel" name="font">
                        <option value="0" disabled>{{ L_('TEXT:PLEASE_SELECT') }} &hellip;</option>
                        {% for p in aFontFiles %}
                            {% set name = p|split('.')[0] %}
                            {% set sel = (name == cfg.font) ? ' selected' : '' %}
                            <option value="{{ name }}"{{ sel }}>{{ name }}</option>
                        {% endfor %}
                    </select>                
                </div>
            </div>

            {# Font Size #}
            <div class="formRow">
                <div class="settingName">
                    <label>Font {{ L_('TEXT:SIZE') }}</label>
                </div>            
                <div class="settingValue">
                    <select id="font_size_sel" name="font_size">
                        <option value="0" disabled>{{ L_('TEXT:PLEASE_SELECT') }} &hellip;</option>
                        {% for p in aFontSizes %}
                            {% set sel = (p == cfg.font_size) ? ' selected' : '' %}
                            <option value="{{ p }}"{{ sel }}>{{ p }}px</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

        </div>{# /dd-settings-section #}
        
        <div class="buttonsRow">
            <button type="submit" name="save_settings" class="button ico-save pos-right">{{ L_('TEXT:SAVE') }}</button>
        </div>
    </form>
</div>    
{% endblock %}