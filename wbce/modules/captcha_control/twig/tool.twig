{#
    captcha_control/twig/tool.twig

    Variables:
      FTAN              — FTAN hidden input (raw HTML)
      RETURN_URL        — form action URL
      RETURN_TO_TOOLS   — back-button URL (tools list)
      USEABLE_CAPTCHAS  — { key: label } map of available captcha types
      CAPTCHA_TYPE      — currently active type key
      ENABLED_CAPTCHA   — '1' or '0'
      ENABLED_ASP       — '1' or '0'
      ALTCHA            — { auto, delay, hidefooter, hidelogo,
                            color_brand, color_success,
                            color_base, color_checkbox,
                            color_text, border_radius }
      WBECOLORIS_CSS       — URL to wbeColoris.css
      WBECOLORIS_ADMIN_CSS — URL to wbeColoris.admin.css
      WBECOLORIS_JS        — URL to wbeColoris.js
      Language strings are accessed directly via L_('CAPTCHA:KEY') in the template.
#}


<form name="store_settings" action="{{ RETURN_URL }}" method="post">
    {{ FTAN|raw }}
    <input type="hidden" name="captcha_type" value="altcha">
    <div class="cp-settings">
        <div class="cp-toggle-section cp-card-body">
            <div class="cp-card-head">
                <label><i class="fa fa-shield"></i> {{ L_('CAPTCHA:HEADING') }}</label>
            </div>

            <blockquote>
                    <p><b>{{ L_('CAPTCHA:CAPTCHA_EXP') }}</b></p>
                    <p>{{ L_('CAPTCHA:HOWTO') }}</p>
                </blockquote>
                {% if USEABLE_CAPTCHAS|length > 1 %}
                {# ── CAPTCHA Type ──────────────────────────────────────────── #}
                <div class="cp-setting-row">
                    <div class="cp-setting-name">{{ L_('CAPTCHA:CAPTCHA_TYPE') }}</div>
                    <div class="cp-setting-value">
                        {% for key, text in USEABLE_CAPTCHAS %}
                            <div class="captcha-option cb">
                                <label>
                                    <input type="radio" name="captcha_type" value="{{ key }}"
                                        {{ (key == CAPTCHA_TYPE) ? 'checked="checked"' : '' }}>
                                    {{ text }}
                                </label>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                {# ── Enable Captcha ────────────────────────────────────────── #}
                <div class="cp-setting-row">
                    <div class="cp-setting-name">{{ L_('CAPTCHA:USE_SIGNUP_CAPTCHA') }}</div>
                    <div class="cp-setting-value">
                        <div class="cb">
                            <label>
                                <input type="radio" name="enabled_captcha" value="1"
                                    {{ (ENABLED_CAPTCHA == '1') ? 'checked="checked"' : '' }}>
                                {{ L_('TXEXT:ENABLED') }}
                            </label>
                            <label style="margin-left:20px;">
                                <input type="radio" name="enabled_captcha" value="0"
                                    {{ (ENABLED_CAPTCHA == '0') ? 'checked="checked"' : '' }}>
                                {{ L_('TXEXT:DISABLED') }}
                            </label>
                        </div>
                    </div>
                </div>

                {# ── Advanced Spam Protection (Honeypot) ───────────────────── #}
                <div class="cp-setting-row">
                    <div class="cp-setting-name">{{ L_('CAPTCHA:ASP_LABEL') }}</div>
                    <div class="cp-setting-value">
                        <div class="cb">
                            <label>
                                <input type="radio" name="enabled_asp" value="1"
                                    {{ (ENABLED_ASP == '1') ? 'checked="checked"' : '' }}>
                                {{ L_('TXEXT:ENABLED') }}
                            </label>
                            <label style="margin-left:20px;">
                                <input type="radio" name="enabled_asp" value="0"
                                    {{ (ENABLED_ASP == '0') ? 'checked="checked"' : '' }}>
                                {{ L_('TXEXT:DISABLED') }}
                            </label>
                        </div>
                        <div class="cp-setting-hint">{{ L_('CAPTCHA:ASP_DESCRIPTION') }}</div>
                    </div>
                </div>
                <blockquote class="info">&nbsp;{{ L_("CAPTCHA:MODULES_SETTINGS_INFO") }}</blockquote>

                {# ══ ALTCHA Widget-Anpassung ════════════════════════════════ #}
                <div class="cp-card-head" id="config">
                    <label><i class="fa fa-wrench"></i> {{ L_('CAPTCHA:WIDGET_HEADING') }}</label>
                </div>
                {# ── Two-column body ──────────────────────────────────────── #}
                <section class="has-aside">
                <div class="cp-card-main">

                    {# ── Start-Modus ────────────────────────────────────────── #}
                    <div class="cp-setting-row">
                        <div class="cp-setting-name">{{ L_('CAPTCHA:AUTO_LABEL') }}</div>
                        <div class="cp-setting-value">
                            <div class="altcha-h-radios">
                                <label><input type="radio" name="altcha_auto" value="off"
                                    {{ ALTCHA.auto == 'off'      ? 'checked' : '' }}
                                    onchange="altchaUpdatePreview()"> {{ L_('CAPTCHA:AUTO_OFF') }}</label>
                                <label><input type="radio" name="altcha_auto" value="onload"
                                    {{ ALTCHA.auto == 'onload'   ? 'checked' : '' }}
                                    onchange="altchaUpdatePreview()"> {{ L_('CAPTCHA:AUTO_ONLOAD') }}</label>
                                <label><input type="radio" name="altcha_auto" value="onsubmit"
                                    {{ ALTCHA.auto == 'onsubmit' ? 'checked' : '' }}
                                    onchange="altchaUpdatePreview()"> {{ L_('CAPTCHA:AUTO_ONSUBMIT') }}</label>
                            </div>
                        </div>
                    </div>

                    {# ── Akzentfarbe ────────────────────────────────────────── #}
                    <div class="cp-setting-row">
                        <div class="cp-setting-name">
                            {{ L_('CAPTCHA:COLOR_BRAND') }}<br>
                            <small style="font-weight:normal;">{{ L_('CAPTCHA:COLOR_BRAND_HINT')|raw }}</small>
                        </div>
                        <div class="cp-setting-value">
                            <input type="text" id="altcha_color_brand" name="altcha_color_brand"
                                   class="altcha-coloris" data-wbecoloris
                                   value="{{ ALTCHA.color_brand }}"
                                   placeholder="{{ L_('CAPTCHA:COLOR_DEFAULT') }}">
                        </div>
                    </div>

                    {# ── Check-Farbe ────────────────────────────────────────── #}
                    <div class="cp-setting-row">
                        <div class="cp-setting-name">{{ L_('CAPTCHA:COLOR_SUCCESS') }}</div>
                        <div class="cp-setting-value">
                            <input type="text" id="altcha_color_success" name="altcha_color_success"
                                   class="altcha-coloris" data-wbecoloris
                                   value="{{ ALTCHA.color_success }}"
                                   placeholder="{{ L_('CAPTCHA:COLOR_DEFAULT') }}">
                        </div>
                    </div>

                    {# ── Widget-Hintergrund ─────────────────────────────────── #}
                    <div class="cp-setting-row">
                        <div class="cp-setting-name">{{ L_('CAPTCHA:COLOR_BASE') }}</div>
                        <div class="cp-setting-value">
                            <input type="text" id="altcha_color_base" name="altcha_color_base"
                                   class="altcha-coloris" data-wbecoloris
                                   value="{{ ALTCHA.color_base }}"
                                   placeholder="{{ L_('CAPTCHA:COLOR_DEFAULT') }}">
                        </div>
                    </div>

                    {# ── Checkbox-Hintergrund ───────────────────────────────── #}
                    <div class="cp-setting-row">
                        <div class="cp-setting-name">{{ L_('CAPTCHA:COLOR_CHECKBOX') }}</div>
                        <div class="cp-setting-value">
                            <input type="text" id="altcha_color_checkbox" name="altcha_color_checkbox"
                                   class="altcha-coloris" data-wbecoloris
                                   value="{{ ALTCHA.color_checkbox }}"
                                   placeholder="{{ L_('CAPTCHA:COLOR_DEFAULT') }}">
                        </div>
                    </div>

                    {# ── Textfarbe ──────────────────────────────────────────── #}
                    <div class="cp-setting-row">
                        <div class="cp-setting-name">{{ L_('CAPTCHA:COLOR_TEXT') }}</div>
                        <div class="cp-setting-value">
                            <input type="text" id="altcha_color_text" name="altcha_color_text"
                                   class="altcha-coloris" data-wbecoloris
                                   value="{{ ALTCHA.color_text }}"
                                   placeholder="{{ L_('CAPTCHA:COLOR_DEFAULT') }}">
                        </div>
                    </div>

                    {# ── Eckenrundung ───────────────────────────────────────── #}
                    <div class="cp-setting-row">
                        <div class="cp-setting-name">{{ L_('CAPTCHA:BORDER_RADIUS') }}</div>
                        <div class="cp-setting-value">
                            <div class="altcha-h-radios">
                                <label><input type="radio" name="altcha_border_radius" value=""
                                    {{ ALTCHA.border_radius == ''    ? 'checked' : '' }}
                                    onchange="altchaUpdatePreview()"> {{ L_('CAPTCHA:COLOR_DEFAULT') }}</label>
                                <label><input type="radio" name="altcha_border_radius" value="0px"
                                    {{ ALTCHA.border_radius == '0px' ? 'checked' : '' }}
                                    onchange="altchaUpdatePreview()">
                                    {{ L_('CAPTCHA:CORNER_SQUARE') }} <small>(0px)</small></label>
                                <label><input type="radio" name="altcha_border_radius" value="4px"
                                    {{ ALTCHA.border_radius == '4px' ? 'checked' : '' }}
                                    onchange="altchaUpdatePreview()">
                                    {{ L_('CAPTCHA:CORNER_LIGHT') }} <small>(4px)</small></label>
                                <label><input type="radio" name="altcha_border_radius" value="12px"
                                    {{ ALTCHA.border_radius == '12px' ? 'checked' : '' }}
                                    onchange="altchaUpdatePreview()">
                                    {{ L_('CAPTCHA:CORNER_ROUND') }} <small>(12px)</small></label>
                            </div>
                        </div>
                    </div>
                    </div>{# /cp-card-main #}

                <div class="cp-card-aside">
                {# ── Live-Vorschau ──────────────────────────────────────────── #}
                <div class="cp-setting-row" style="margin-top:16px;">
                    <div class="cp-setting-name" style="padding-top:12px;"><b>{{ L_('CAPTCHA:PREVIEW') }}</b></div>
                    <div class="cp-setting-value">
                        <div class="altcha-mock" id="altcha-mock">
                            <div class="altcha-mock-body">
                                <div class="altcha-mock-cb-pair">
                                    <div class="altcha-mock-cb" id="altcha-mock-cb-un"></div>
                                    <div class="altcha-mock-cb altcha-mock-cb-checked" id="altcha-mock-cb">
                                        <svg id="altcha-mock-check" class="altcha-mock-check"
                                             viewBox="0 0 11 9" fill="none"
                                             xmlns="http://www.w3.org/2000/svg">
                                            <polyline points="1,7 4,8.5 10,1"
                                                stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="altcha-mock-text" id="altcha-mock-text">Ich bin kein Roboter</div>
                                <span id="altcha-mock-logo" class="altcha-mock-logo" title="ALTCHA">
                                    <svg width="24" height="24" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.33955 16.4279C5.88954 20.6586 12.1971 21.2105 16.4279 17.6604C18.4699 15.947 19.6548 13.5911 19.9352 11.1365L17.9886 10.4279C17.8738 12.5624 16.909 14.6459 15.1423 16.1284C11.7577 18.9684 6.71167 18.5269 3.87164 15.1423C1.03163 11.7577 1.4731 6.71166 4.8577 3.87164C8.24231 1.03162 13.2883 1.4731 16.1284 4.8577C16.9767 5.86872 17.5322 7.02798 17.804 8.2324L19.9522 9.01429C19.7622 7.07737 19.0059 5.17558 17.6604 3.57212C14.1104 -0.658624 7.80283 -1.21043 3.57212 2.33956C-0.658625 5.88958 -1.21046 12.1971 2.33955 16.4279Z" fill="currentColor"/><path d="M3.57212 2.33956C1.65755 3.94607 0.496389 6.11731 0.12782 8.40523L2.04639 9.13961C2.26047 7.15832 3.21057 5.25375 4.8577 3.87164C8.24231 1.03162 13.2883 1.4731 16.1284 4.8577L13.8302 6.78606L19.9633 9.13364C19.7922 7.15555 19.0335 5.20847 17.6604 3.57212C14.1104 -0.658624 7.80283 -1.21043 3.57212 2.33956Z" fill="currentColor"/><path d="M7 10H5C5 12.7614 7.23858 15 10 15C12.7614 15 15 12.7614 15 10H13C13 11.6569 11.6569 13 10 13C8.3431 13 7 11.6569 7 10Z" fill="currentColor"/></svg>
                                </span>
                            </div>
                            <div class="altcha-mock-footer" id="altcha-mock-footer">
                                <span>{{ L_('CAPTCHA:WIDGET_FOOTER_TEXT') }}</span>
                            </div>
                        </div>

                        <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:6px 24px;">
                            <label style="display:flex;align-items:center;gap:5px;cursor:pointer;font-weight:normal;">
                                <input type="checkbox" id="altcha_hidefooter_cb" name="altcha_hidefooter" value="1"
                                       {{ ALTCHA.hidefooter ? 'checked' : '' }}
                                       onchange="altchaUpdatePreview()">
                                {{ L_('CAPTCHA:HIDEFOOTER') }}
                            </label>
                            <label style="display:flex;align-items:center;gap:5px;cursor:pointer;font-weight:normal;">
                                <input type="checkbox" id="altcha_hidelogo_cb" name="altcha_hidelogo" value="1"
                                       {{ ALTCHA.hidelogo ? 'checked' : '' }}
                                       onchange="altchaUpdatePreview()">
                                {{ L_('CAPTCHA:HIDELOGO') }}
                            </label>
                        </div>
                    </div>
                </div>{# /cp-card-aside #}
                </section>{# /has-aside #}

                {# ── Buttons ───────────────────────────────────────────────── #}
                <div class="cp-buttons-row">
                    <a href="{{ RETURN_TO_TOOLS }}" class="button">&laquo; {{ L_('TEXT:BACK') }}</a>
                    <button type="submit" name="save_settings" class="button ico-save pos-right">
                        {{ L_('TEXT:SAVE') }}
                    </button>
                </div>

        </div>
    </div>
</form>
               
                    
<script>
(function () {
    'use strict';

    function el(id) { return document.getElementById(id); }

    // ── WbeColoris global config — labels come from wbeColoris.i18n.js ────────
    WbeColoris({
        alpha:    false,
        format:   'hex',
        themeMode:'light',
        okButton: true,
        onChange: function () { altchaUpdatePreview(); }
    });

    // ── Per-field: swatches + defaultColor ────────────────────────────────────
    WbeColoris.setInstance('#altcha_color_brand', {
        defaultColor: '#6d28d9',
        swatches: ['#6d28d9', '#2563eb', '#16a34a', '#ea580c', '#dc2626']
    });
    WbeColoris.setInstance('#altcha_color_success', {
        defaultColor: '#16a34a',
        swatches: ['#16a34a', '#2563eb', '#ea580c', '#dc2626', '#6d28d9']
    });
    WbeColoris.setInstance('#altcha_color_base', {
        defaultColor: '#ffffff',
        swatches: ['#ffffff', '#f9fafb', '#e5e7eb', '#374151', '#1f2937']
    });
    WbeColoris.setInstance('#altcha_color_checkbox', {
        defaultColor: '#ffffff',
        swatches: ['#ffffff', '#f9fafb', '#e5e7eb', '#374151', '#1f2937']
    });
    WbeColoris.setInstance('#altcha_color_text', {
        defaultColor: '#111827',
        swatches: ['#111827', '#374151', '#6b7280', '#f9fafb', '#ffffff']
    });

    // ── Preview helpers ───────────────────────────────────────────────────────

    // Rec. 601 luma contrast — mirrors PHP auto-contrast logic
    function autoContrast(hex) {
        if (!hex || hex.length !== 7) { return '#111827'; }
        var rr = parseInt(hex.slice(1, 3), 16) / 255,
            gg = parseInt(hex.slice(3, 5), 16) / 255,
            bb = parseInt(hex.slice(5, 7), 16) / 255;
        return (0.299 * rr + 0.587 * gg + 0.114 * bb) < 0.5 ? '#f9fafb' : '#111827';
    }

    function altchaUpdatePreview() {
        var mock   = el('altcha-mock');
        var footer = el('altcha-mock-footer');
        var logo   = el('altcha-mock-logo');
        var cbUn   = el('altcha-mock-cb-un');
        var cbCh   = el('altcha-mock-cb');
        var check  = el('altcha-mock-check');
        var text   = el('altcha-mock-text');
        if (!mock) { return; }

        var brand   = el('altcha_color_brand').value   || '#6d28d9';
        var success = el('altcha_color_success').value || '#16a34a';
        var base    = el('altcha_color_base').value    || '#ffffff';
        var cbBg    = el('altcha_color_checkbox').value;
        var textRaw = el('altcha_color_text').value;

        var color     = textRaw || autoContrast(base || '#ffffff');
        var tickColor = autoContrast(success);

        var radRadius = document.querySelector('[name="altcha_border_radius"]:checked');
        var radius    = radRadius ? (radRadius.value || '6px') : '6px';

        var hidefooter = el('altcha_hidefooter_cb') && el('altcha_hidefooter_cb').checked;
        var hidelogo   = el('altcha_hidelogo_cb')   && el('altcha_hidelogo_cb').checked;

        mock.style.background   = base;
        mock.style.borderRadius = radius;
        mock.style.borderColor  = (base === '#ffffff' || base === '') ? '#d1d5db' : base;

        if (text)   { text.style.color = color; }
        if (footer) { footer.style.display = hidefooter ? 'none' : ''; footer.style.color = color; }
        if (logo)   { logo.style.display   = hidelogo   ? 'none' : ''; logo.style.color   = color; }

        if (cbUn) { cbUn.style.borderColor = brand; cbUn.style.background = cbBg || base || '#ffffff'; }
        if (cbCh) { cbCh.style.borderColor = success; cbCh.style.background = success; }
        if (check) { check.style.color = tickColor; }
    }

    // Expose for inline onchange handlers (radios, checkboxes)
    window.altchaUpdatePreview = altchaUpdatePreview;

    // Initial render on page load
    altchaUpdatePreview();
}());
</script>
