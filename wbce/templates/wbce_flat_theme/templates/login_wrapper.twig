{#
    login_wrapper.twig — Outer chrome for login pages — WBCE Flat Theme

    Blocks:
      title        — <title> text
      body_attrs   — extra attributes on <body>
      login_content — page content inside .page_login_form
#}
<!DOCTYPE html>
<html lang="{{ LANGUAGE }}">
<head>
<title>{% block title %}{{ L_('TEXT:LOGIN') }}{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="content-type" content="text/html; charset={{ CHARSET }}" />
    <meta http-equiv="content-language" content="{{ LANGUAGE }}" />
    <link rel="icon" type="image/x-icon" href="{{ WB_URL }}/favicon.ico">

    <link rel="stylesheet" href="{{ THEME_URL }}/css/normalize.css">
    <link rel="stylesheet" href="{{ THEME_URL }}/css/login.css?171717">
    <link href="{{ WB_URL }}/templates/theme_fallbacks/css/cp_chrome.css" rel="stylesheet">
    <link href="{{ theme_file('../css/cp_alerts.css') }}" rel="stylesheet">
    <style>
    
    </style>
<script type="text/javascript" src="{{ WB_URL }}/include/jquery/jquery-min.js"></script>
</head>
<body class="page_login"{% block body_attrs %}{% endblock %}>

    <div class="page_login_header">
        <div class="page_login_logo">WBCE CMS</div>
        <div class="page_login_slogan">Way Better Content Editing.</div>
    </div>

    <div class="page_login_form">
        {% block login_content %}{% endblock %}
        <p class="login_license">
            {# Please note: the below reference to the GNU GPL should not be removed, as it provides a link for users to read about warranty, etc. #}
            <a href="http://www.wbce.org/" title="Visit wbce.org">WBCE</a> is released under the <a href="http://www.gnu.org/licenses/gpl.html" title="GNU General Public License">GNU General Public License</a>
        </p>
    </div>
</body>
</html>
